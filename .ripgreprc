# Smart case: case-insensitive unless uppercase is used
--smart-case

# Search inside hidden files and directories
--hidden

# Exclude common noise directories
--glob=!.git
--glob=!node_modules
--glob=!.venv
--glob=!venv
--glob=!__pycache__
--glob=!.pytest_cache
--glob=!.terraform
--glob=!vendor
--glob=!dist
--glob=!build
--glob=!coverage

# Follow symlinks
--follow

# Truncate long lines (show preview of truncated content)
--max-columns=200
--max-columns-preview
