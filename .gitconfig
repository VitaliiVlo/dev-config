[user]
	email = vitalii.vlo@gmail.com
	name = vitalii-vlo

[url "git@github.com:"]
	insteadOf = https://github.com/

[core]
	autocrlf = input
	safecrlf = warn
	excludesfile = ~/.gitignore_global
	editor = code --wait
	pager = delta

[interactive]
	diffFilter = delta --color-only

[delta]
	navigate = true
	dark = true
	line-numbers = true
	hyperlinks = true
	side-by-side = true
	tabs = 4
	syntax-theme = Catppuccin Macchiato

[fetch]
	prune = true

[pull]
	rebase = true

[rebase]
	autostash = true

[init]
	defaultBranch = main

[diff]
	colorMoved = default
	algorithm = histogram
	mnemonicPrefix = true
	renames = true

[merge]
	conflictstyle = zdiff3

[rerere]
	enabled = true
	autoupdate = true

[push]
	autoSetupRemote = true

[alias]
	# Daily basics
	st = status
	df = diff
	dfs = diff --staged
	dfw = diff --word-diff
	dfws = diff --staged --word-diff
	# Commits
	cm = commit -m
	ca = commit --amend --no-edit
	# Log
	lg = log --oneline --graph --decorate
	# Undo
	undo = reset --soft HEAD~1
	wipe = reset --hard HEAD

[log]
	date = relative

[branch]
	sort = -committerdate
