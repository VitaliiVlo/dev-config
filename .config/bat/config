# Theme (follows macOS appearance)
--theme-dark="Catppuccin Macchiato"
--theme-light="Catppuccin Latte"

# Display
--style="numbers,changes,header,grid"
--italic-text=always
--tabs=4
--wrap=auto

# Pager
--pager="less --RAW-CONTROL-CHARS --quit-if-one-screen"

# Syntax mappings (only entries bat does not map natively)
--map-syntax ".gitignore:Git Ignore"
--map-syntax ".dockerignore:Git Ignore"
--map-syntax ".env*:Dotenv"
--map-syntax "Brewfile:Ruby"
--map-syntax "*.conf:INI"
