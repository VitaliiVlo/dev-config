    "tabsize": 4,
    "tabstospaces": true,
    "savecursor": true,
    "scrollbar": true,
    "scrollmargin": 3,
    "hlsearch": true,
    "diffgutter": true,
    "basename": true,
    "rmtrailingws": true,
